---
/**
 * TestimonialCard.astro
 * Star rating + blockquote + figcaption testimonial card.
 * Referencia: docs/patterns/design-system.md → "Social proof"
 */

interface Props {
  quote: string;
  name: string;
  role: string;
  initial: string;
  stars?: number;
}

const { quote, name, role, initial, stars = 5 } = Astro.props;
---

<figure class="rounded-xl border border-neutral-200 bg-white p-6 flex flex-col gap-4">
  <!-- Stars -->
  <div class="flex gap-0.5" aria-label={`${stars} de 5 estrellas`}>
    {
      Array.from({ length: stars }).map(() => (
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="text-amber-400"
          aria-hidden="true"
        >
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
        </svg>
      ))
    }
  </div>

  <blockquote class="text-sm text-neutral-700 leading-relaxed flex-1">
    <p>&ldquo;{quote}&rdquo;</p>
  </blockquote>

  <figcaption class="flex items-center gap-3">
    <span
      class="flex items-center justify-center w-9 h-9 rounded-full bg-primary-100 text-primary-700 font-bold text-sm shrink-0"
      aria-hidden="true"
    >
      {initial}
    </span>
    <div>
      <p class="text-sm font-semibold text-neutral-900">{name}</p>
      <p class="text-xs text-neutral-500">{role}</p>
    </div>
  </figcaption>
</figure>
