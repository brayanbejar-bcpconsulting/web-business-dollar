---
/**
 * SectionHeader.astro
 * Centered or left-aligned h2 + optional subtext for section headers.
 * Referencia: docs/patterns/design-system.md → "Section headers"
 */

interface Props {
  heading: string;
  subtext?: string;
  align?: "left" | "center";
  id?: string;
  mb?: string;
}

const { heading, subtext, align = "center", id, mb = "mb-12" } = Astro.props;

const alignClasses = align === "center" ? "text-center mx-auto" : "text-left";
---

<div class={`max-w-2xl ${alignClasses} ${mb}`}>
  <h2
    class="font-display text-2xl md:text-3xl font-bold text-neutral-900 mb-3 leading-tight"
    {id}
  >
    {heading}
  </h2>
  {subtext && <p class="text-neutral-600 leading-relaxed">{subtext}</p>}
</div>
