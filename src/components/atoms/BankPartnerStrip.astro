---
/**
 * BankPartnerStrip.astro
 * Strip of bank partner pills.
 * Referencia: docs/patterns/design-system.md → "Trust indicators"
 */

import { bankPartners } from "../../data/company";

interface Props {
  label?: string;
  align?: "left" | "center";
  class?: string;
}

const { label, align = "left", class: className = "" } = Astro.props;
---

<div class={`flex flex-wrap gap-2 ${align === "center" ? "justify-center" : ""} ${className}`}>
  {label && <span class="text-xs text-neutral-500 self-center mr-1">{label}</span>}
  {
    bankPartners.map((bank) => (
      <span class="text-xs font-medium bg-white border border-neutral-200 text-neutral-600 px-3 py-1 rounded-full">
        {bank}
      </span>
    ))
  }
</div>
