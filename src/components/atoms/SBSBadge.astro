---
/**
 * SBSBadge.astro
 * Pill badge: "Regulado por la SBS del Perú".
 * Referencia: docs/patterns/design-system.md → "Trust indicators"
 */

interface Props {
  variant?: "light" | "dark";
  class?: string;
}

const { variant = "light", class: className = "" } = Astro.props;

const containerClasses =
  variant === "dark"
    ? "inline-flex items-center gap-2 px-3 py-1.5 rounded-md bg-neutral-800 border border-neutral-700 text-xs text-neutral-300"
    : "inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-primary-50 border border-primary-200 text-xs font-semibold text-primary-700";

const iconClasses =
  variant === "dark" ? "text-primary-400 shrink-0" : "text-primary-600 shrink-0";
---

<div class={`${containerClasses} ${className}`}>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="14"
    height="14"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class={iconClasses}
    aria-hidden="true"
  >
    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10" />
  </svg>
  {
    variant === "dark" ? (
      <span>Regulado por la <strong class="text-white">SBS</strong></span>
    ) : (
      <span>Regulado por la SBS del Perú</span>
    )
  }
</div>
