---
/**
 * Footer.astro
 * Pie de página global del sitio. Incluye:
 * - Links de navegación por sección
 * - Información legal (RUC, registro SBS)
 * - Redes sociales
 * - Disclaimers YMYL obligatorios
 * - Links legales (términos, privacidad, cookies, reclamaciones)
 * Referencia: docs/context/business-logic.md → EEAT / Trustworthiness
 * Referencia: docs/patterns/seo-rules.md → YMYL disclaimers
 */

import { company, social } from "../../data/company";
import SBSBadge from "../atoms/SBSBadge.astro";

const footerNav = [
  {
    heading: "Servicios",
    links: [
      { label: "Comprar dólares", href: "/servicios#comprar" },
      { label: "Vender dólares", href: "/servicios#vender" },
      { label: "Tipo de cambio", href: "/tipo-de-cambio" },
      { label: "Calculadora de cambio", href: "/calculadora-tipo-de-cambio" },
    ],
  },
  {
    heading: "Información",
    links: [
      { label: "Sobre nosotros", href: "/sobre-nosotros" },
      { label: "Seguridad", href: "/seguridad" },
      { label: "Preguntas frecuentes", href: "/preguntas-frecuentes" },
      { label: "Contacto", href: "/contacto" },
    ],
  },
  {
    heading: "Contenido",
    links: [
      { label: "Blog financiero", href: "/blog" },
      { label: "Tipo de cambio hoy", href: "/blog/categoria/tipo-de-cambio" },
      { label: "Guías de cambio", href: "/blog/categoria/guias" },
      { label: "Finanzas personales", href: "/blog/categoria/finanzas" },
    ],
  },
  {
    heading: "Legal",
    links: [
      { label: "Términos y condiciones", href: "/terminos-y-condiciones" },
      { label: "Política de privacidad", href: "/politica-de-privacidad" },
      { label: "Política de cookies", href: "/politica-de-cookies" },
      { label: "Libro de reclamaciones", href: "/libro-de-reclamaciones" },
    ],
  },
];

const currentYear = new Date().getFullYear();
---

<footer class="bg-neutral-900 text-neutral-300" aria-label="Pie de página">
  <!-- Main footer content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-8">
    <!-- Top row: logo + tagline + social -->
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-8 mb-12">
      <!-- Brand -->
      <div class="max-w-xs">
        <a
          href="/"
          class="inline-flex items-center gap-2 font-display font-bold text-xl text-white hover:text-primary-400 transition-colors duration-150 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 rounded-sm"
          aria-label="Business Dollar — Inicio"
        >
          <span
            class="flex items-center justify-center w-8 h-8 rounded-lg bg-primary-600 text-white text-sm font-bold"
            aria-hidden="true"
          >$</span>
          <span>Business <span class="text-primary-400">Dollar</span></span>
        </a>
        <p class="mt-3 text-sm text-neutral-400 leading-relaxed">
          Casa de cambio digital regulada por la SBS. Cambia dólares online de forma segura y al mejor tipo de cambio del mercado.
        </p>
        <!-- SBS badge -->
        <div class="mt-4">
          <SBSBadge variant="dark" />
        </div>
      </div>

      <!-- Social links -->
      <div class="flex items-center gap-3">
        <span class="text-xs text-neutral-500 mr-1">Síguenos:</span>
        {
          [
            {
              href: social.facebook,
              label: "Facebook de Business Dollar",
              icon: (
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />
                </svg>
              ),
            },
            {
              href: social.instagram,
              label: "Instagram de Business Dollar",
              icon: (
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect width="20" height="20" x="2" y="2" rx="5" ry="5" />
                  <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
                  <line x1="17.5" x2="17.51" y1="6.5" y2="6.5" />
                </svg>
              ),
            },
            {
              href: social.linkedin,
              label: "LinkedIn de Business Dollar",
              icon: (
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                  <rect width="4" height="12" x="2" y="9" />
                  <circle cx="4" cy="4" r="2" />
                </svg>
              ),
            },
          ].map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={s.label}
              class="p-2 rounded-md text-neutral-400 hover:text-white hover:bg-neutral-800 transition-colors duration-150 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500"
            >
              {s.icon}
            </a>
          ))
        }
      </div>
    </div>

    <!-- Nav columns -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
      {
        footerNav.map((section) => (
          <div>
            <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">
              {section.heading}
            </h3>
            <ul class="space-y-2.5" role="list">
              {section.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-neutral-400 hover:text-white transition-colors duration-150 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary-500 rounded-sm"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <!-- CTA strip -->
    <div class="rounded-xl bg-neutral-800 border border-neutral-700 px-6 py-5 flex flex-col sm:flex-row items-center justify-between gap-4 mb-12">
      <div>
        <p class="text-sm font-semibold text-white">¿Listo para cambiar dólares?</p>
        <p class="text-xs text-neutral-400 mt-0.5">Sin comisiones. Sin colas. 100% online.</p>
      </div>
      <a
        href="https://app.business-dollar.pe/register"
        target="_blank"
        rel="noopener noreferrer"
        class="shrink-0 inline-flex items-center gap-2 bg-primary-600 hover:bg-primary-700 text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors duration-150 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-primary-500 focus-visible:ring-offset-neutral-800"
      >
        Abrir cuenta gratis
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M5 12h14" />
          <path d="m12 5 7 7-7 7" />
        </svg>
      </a>
    </div>

    <!-- YMYL disclaimer -->
    <div class="rounded-lg bg-neutral-800/50 border border-neutral-700/50 px-4 py-3 mb-8">
      <p class="text-xs text-neutral-500 leading-relaxed">
        <strong class="text-neutral-400">Aviso importante:</strong> Business Dollar es una casa de cambio digital regulada
        por la Superintendencia de Banca, Seguros y AFP (SBS) del Perú. Las operaciones de cambio de divisas implican
        riesgos inherentes al mercado. El tipo de cambio varía constantemente y los valores mostrados son referenciales.
        Este sitio no proporciona asesoría financiera de inversión. Consulta siempre con un profesional financiero antes de
        tomar decisiones de inversión importantes.
      </p>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-neutral-800 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-neutral-500">
      <div class="flex flex-wrap items-center gap-x-4 gap-y-1">
        <span>&copy; {currentYear} {company.legalName}. Todos los derechos reservados.</span>
        <span class="hidden sm:inline text-neutral-700">|</span>
        <span>RUC: {company.ruc}</span>
        <span class="hidden sm:inline text-neutral-700">|</span>
        <span>Registro SBS N.° {company.sbsRegistro}</span>
      </div>
      <div class="flex items-center gap-1 text-neutral-600">
        <span>Hecho en</span>
        <span class="text-neutral-500">🇵🇪</span>
        <span>Perú</span>
      </div>
    </div>
  </div>
</footer>
