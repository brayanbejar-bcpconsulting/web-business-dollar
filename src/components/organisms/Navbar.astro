---
/**
 * Navbar.astro
 * Navegación principal del sitio. Responsive con menú hamburguesa en mobile,
 * navegación completa visible en desktop.
 * Referencia: docs/context/business-logic.md → Flujo de Conversión
 */

import Button from "../atoms/Button.astro";

const navLinks = [
  { label: "Servicios", href: "/servicios" },
  { label: "Seguridad", href: "/seguridad" },
  { label: "Blog", href: "/blog" },
  { label: "Preguntas frecuentes", href: "/preguntas-frecuentes" },
  { label: "Sobre nosotros", href: "/sobre-nosotros" },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 w-full border-b border-neutral-200 bg-white/95 backdrop-blur-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <nav class="flex items-center justify-between h-16" aria-label="Navegación principal">
      <!-- Logo -->
      <a
        href="/"
        class="flex items-center gap-2 font-display font-bold text-xl text-neutral-900 hover:text-primary-600 transition-colors duration-150 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 rounded-sm"
        aria-label="Business Dollar — Inicio"
      >
        <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-primary-600 text-white text-sm font-bold" aria-hidden="true">$</span>
        <span>Business <span class="text-primary-600">Dollar</span></span>
      </a>

      <!-- Desktop nav links -->
      <ul class="hidden lg:flex items-center gap-1" role="list">
        {
          navLinks.map((link) => {
            const isActive =
              currentPath === link.href ||
              (link.href !== "/" && currentPath.startsWith(link.href));
            return (
              <li>
                <a
                  href={link.href}
                  class={[
                    "px-3 py-2 text-sm font-medium rounded-md transition-colors duration-150 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500",
                    isActive
                      ? "text-primary-600 bg-primary-50"
                      : "text-neutral-600 hover:text-neutral-900 hover:bg-neutral-50",
                  ].join(" ")}
                  aria-current={isActive ? "page" : undefined}
                >
                  {link.label}
                </a>
              </li>
            );
          })
        }
      </ul>

      <!-- Desktop CTA -->
      <div class="hidden lg:flex items-center gap-3">
        <a
          href="https://app.business-dollar.pe/login"
          class="text-sm font-medium text-neutral-600 hover:text-neutral-900 transition-colors duration-150 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 rounded-sm px-2 py-1"
        >
          Ingresar
        </a>
        <Button href="https://app.business-dollar.pe/register" size="sm" target="_blank">
          Abrir cuenta gratis
        </Button>
      </div>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-toggle"
        type="button"
        class="lg:hidden p-2 rounded-md text-neutral-600 hover:text-neutral-900 hover:bg-neutral-100 transition-colors duration-150 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500"
        aria-controls="mobile-menu"
        aria-expanded="false"
        aria-label="Abrir menú de navegación"
      >
        <svg
          id="icon-menu"
          xmlns="http://www.w3.org/2000/svg"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <line x1="4" x2="20" y1="12" y2="12" />
          <line x1="4" x2="20" y1="6" y2="6" />
          <line x1="4" x2="20" y1="18" y2="18" />
        </svg>
        <svg
          id="icon-close"
          xmlns="http://www.w3.org/2000/svg"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          class="hidden"
        >
          <path d="M18 6 6 18" />
          <path d="m6 6 12 12" />
        </svg>
      </button>
    </nav>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden lg:hidden border-t border-neutral-100 bg-white"
    role="navigation"
    aria-label="Menú móvil"
  >
    <div class="max-w-7xl mx-auto px-4 py-3 space-y-1">
      {
        navLinks.map((link) => {
          const isActive =
            currentPath === link.href ||
            (link.href !== "/" && currentPath.startsWith(link.href));
          return (
            <a
              href={link.href}
              class={[
                "block px-3 py-2.5 text-sm font-medium rounded-md transition-colors duration-150",
                isActive
                  ? "text-primary-600 bg-primary-50"
                  : "text-neutral-700 hover:text-neutral-900 hover:bg-neutral-50",
              ].join(" ")}
              aria-current={isActive ? "page" : undefined}
            >
              {link.label}
            </a>
          );
        })
      }
      <div class="pt-3 pb-1 border-t border-neutral-100 flex flex-col gap-2">
        <a
          href="https://app.business-dollar.pe/login"
          class="block px-3 py-2.5 text-sm font-medium text-neutral-700 hover:text-neutral-900 hover:bg-neutral-50 rounded-md transition-colors duration-150"
        >
          Ingresar
        </a>
        <Button href="https://app.business-dollar.pe/register" size="sm" class="w-full justify-center" target="_blank">
          Abrir cuenta gratis
        </Button>
      </div>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const iconMenu = document.getElementById("icon-menu");
  const iconClose = document.getElementById("icon-close");

  toggle?.addEventListener("click", () => {
    const isOpen = menu?.classList.contains("hidden") === false;

    if (isOpen) {
      menu?.classList.add("hidden");
      iconMenu?.classList.remove("hidden");
      iconClose?.classList.add("hidden");
      toggle.setAttribute("aria-expanded", "false");
      toggle.setAttribute("aria-label", "Abrir menú de navegación");
    } else {
      menu?.classList.remove("hidden");
      iconMenu?.classList.add("hidden");
      iconClose?.classList.remove("hidden");
      toggle.setAttribute("aria-expanded", "true");
      toggle.setAttribute("aria-label", "Cerrar menú de navegación");
    }
  });

  // Cerrar al hacer clic en un enlace del menú móvil
  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      menu.classList.add("hidden");
      iconMenu?.classList.remove("hidden");
      iconClose?.classList.add("hidden");
      toggle?.setAttribute("aria-expanded", "false");
    });
  });
</script>
