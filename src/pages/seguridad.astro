---
/**
 * seguridad.astro
 * Página EEAT/YMYL crítica: regulación SBS, medidas técnicas de seguridad,
 * cómo proteger la cuenta, prevención de fraudes.
 * Referencia: docs/context/project-roadmap.md → Fase 2.4
 * Referencia: docs/patterns/seo-rules.md → YMYL obligatorio
 */
import PageLayout from "../layouts/PageLayout.astro";
import PageHero from "../components/sections/PageHero.astro";
import FeatureGrid from "../components/sections/FeatureGrid.astro";
import CTASection from "../components/sections/CTASection.astro";
import YMYLDisclaimer from "../components/sections/YMYLDisclaimer.astro";
import { company } from "../data/company";

const securitySchema = {
  "@type": "WebPage",
  name: "Seguridad en Business Dollar",
  description:
    "Cómo Business Dollar protege tu dinero: regulación SBS, encriptación, autenticación en dos pasos y cumplimiento normativo.",
  url: "https://business-dollar.pe/seguridad",
  about: {
    "@type": "Organization",
    name: "Business Dollar",
    url: "https://business-dollar.pe",
  },
};

const securityFeatures = [
  {
    title: "Regulación SBS",
    body: `Operamos bajo la supervisión directa de la Superintendencia de Banca, Seguros y AFP del Perú (Registro N.° ${company.sbsRegistro}). Cumplimos con todas las disposiciones de la Ley N.° 26702 del Sistema Financiero.`,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>`,
    iconSize: "md" as const,
  },
  {
    title: "Encriptación TLS/SSL",
    body: "Toda la comunicación entre tu navegador y nuestros servidores está cifrada con TLS 1.3. Nunca transmitimos datos sensibles en texto plano.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`,
    iconSize: "md" as const,
  },
  {
    title: "Verificación de identidad (KYC)",
    body: "Cada cliente pasa por un proceso de verificación de identidad (Know Your Customer) conforme a la normativa PLAFT de la SBS, previniendo el fraude y el lavado de activos.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/><polyline points="16 11 17 13 20 10"/></svg>`,
    iconSize: "md" as const,
  },
  {
    title: "Autenticación en dos pasos",
    body: "Ofrecemos autenticación en dos factores (2FA) para proteger tu cuenta incluso si tu contraseña es comprometida.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/></svg>`,
    iconSize: "md" as const,
  },
  {
    title: "Monitoreo de transacciones 24/7",
    body: "Nuestro sistema detecta automáticamente patrones inusuales y bloquea operaciones sospechosas en tiempo real para proteger tu dinero.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`,
    iconSize: "md" as const,
  },
  {
    title: "Cumplimiento PLAFT",
    body: "Cumplimos con el Sistema de Prevención del Lavado de Activos y Financiamiento del Terrorismo (PLAFT) conforme a las resoluciones SBS vigentes.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
    iconSize: "md" as const,
  },
];

const tips = [
  "Nunca compartas tu contraseña con nadie, incluido personal de Business Dollar.",
  "Activa el 2FA (autenticación en dos pasos) en tu cuenta.",
  "Verifica que la URL sea exactamente https://app.business-dollar.pe antes de ingresar tus datos.",
  "No operes desde redes WiFi públicas no confiables.",
  "Si recibes un correo sospechoso sobre tu cuenta, no hagas clic en ningún enlace — contáctanos directamente.",
  "Revisa regularmente el historial de operaciones en tu cuenta.",
  "Usa una contraseña única y fuerte para tu cuenta (mínimo 12 caracteres, combinando letras, números y símbolos).",
];

const redFlags = [
  "Personas que te ofrecen tipos de cambio \"demasiado buenos para ser verdad\"",
  "Solicitudes de pago por adelantado sin registro ni contrato",
  "Casas de cambio sin registro SBS verificable",
  "Sitios web que imitan marcas conocidas con URLs similares pero diferentes",
  "Solicitudes de datos sensibles por teléfono, WhatsApp o email",
];
---

<PageLayout
  title="Seguridad en Business Dollar — Cómo protegemos tu dinero"
  description="Conoce cómo Business Dollar protege tu dinero: regulación SBS, encriptación TLS, verificación KYC, 2FA y cumplimiento PLAFT. Cambia dólares con total seguridad."
  schema={securitySchema}
  breadcrumbs={[{ label: "Seguridad", href: "/seguridad" }]}
>
  <PageHero
    heading="Tu seguridad es nuestra prioridad"
    subheading="En Business Dollar tomamos la seguridad de tus operaciones con la máxima seriedad. Combinamos regulación estatal, tecnología de encriptación y procesos internos rigurosos para proteger tu dinero en cada operación."
    align="left"
    badge={{ text: "Regulado por la SBS del Perú", variant: "sbs" }}
  />

  <FeatureGrid
    items={securityFeatures}
    cols={3}
    heading="Nuestras medidas de seguridad"
    subtext="Un sistema de múltiples capas de protección para que tu dinero esté siempre seguro."
    bg="bg-neutral-50"
  />

  <!-- Regulación SBS detalle -->
  <section class="py-16 bg-white" aria-labelledby="sbs-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 id="sbs-heading" class="font-display text-3xl font-bold text-neutral-900 mb-4">
            ¿Qué significa estar regulado por la SBS?
          </h2>
          <p class="text-neutral-600 leading-relaxed mb-4">
            La Superintendencia de Banca, Seguros y AFP (SBS) es el organismo del Estado Peruano que supervisa y regula todas las entidades del sistema financiero, incluyendo las casas de cambio digitales como Business Dollar.
          </p>
          <p class="text-neutral-600 leading-relaxed mb-4">
            Al estar registrados en la SBS, debemos cumplir con estándares estrictos de capital, liquidez, controles internos y prevención de lavado de activos. Esto te protege como usuario.
          </p>
          <p class="text-neutral-600 leading-relaxed mb-6">
            Puedes verificar nuestro registro directamente en el portal oficial de la SBS: <a href="https://www.sbs.gob.pe" target="_blank" rel="noopener noreferrer" class="text-accent-600 hover:underline">www.sbs.gob.pe</a>.
          </p>
          <div class="flex items-center gap-3 p-4 rounded-xl bg-primary-50 border border-primary-100">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-600 shrink-0" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
            <div>
              <p class="text-sm font-semibold text-primary-800">{company.legalName}</p>
              <p class="text-xs text-primary-600">Registro SBS N.° {company.sbsRegistro}</p>
            </div>
          </div>
        </div>

        <div class="bg-neutral-50 rounded-xl p-6 border border-neutral-200">
          <h3 class="font-semibold text-neutral-900 mb-4">Como usuario registrado, tienes derecho a:</h3>
          <ul class="space-y-3">
            {[
              "Recibir información clara sobre el tipo de cambio aplicado",
              "Obtener comprobante de cada operación realizada",
              "Presentar reclamos ante Business Dollar y ante la SBS",
              "Que tus datos personales sean tratados con confidencialidad",
              "Cancelar operaciones dentro de los plazos establecidos",
              "Atención al cliente oportuna y profesional",
            ].map((right) => (
              <li class="flex items-start gap-2.5 text-sm text-neutral-600">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary-500 shrink-0 mt-0.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                {right}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Consejos de seguridad + señales de alerta -->
  <section class="py-16 bg-neutral-50" aria-labelledby="tips-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-8">
        <div>
          <h2 id="tips-heading" class="font-display text-2xl font-bold text-neutral-900 mb-6">
            Cómo proteger tu cuenta
          </h2>
          <ul class="space-y-3">
            {tips.map((tip, i) => (
              <li class="flex items-start gap-3">
                <span class="flex items-center justify-center w-6 h-6 rounded-full bg-primary-100 text-primary-700 text-xs font-bold shrink-0 mt-0.5" aria-hidden="true">{i + 1}</span>
                <p class="text-sm text-neutral-700 leading-relaxed">{tip}</p>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <h2 class="font-display text-2xl font-bold text-neutral-900 mb-6">
            Señales de alerta — fraudes comunes
          </h2>
          <div class="bg-red-50 rounded-xl border border-red-100 p-5">
            <p class="text-sm font-semibold text-red-800 mb-4">
              Desconfía si encuentras alguna de estas señales:
            </p>
            <ul class="space-y-3">
              {redFlags.map((flag) => (
                <li class="flex items-start gap-2.5 text-sm text-red-700">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 mt-0.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                  {flag}
                </li>
              ))}
            </ul>
            <p class="mt-4 text-xs text-red-600">
              Ante cualquier duda, contáctanos en <a href={`mailto:${company.email}`} class="font-semibold underline">{company.email}</a>.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <YMYLDisclaimer />

  <CTASection
    variant="primary"
    heading="Cambia dólares con total confianza"
    subtext="Regulados por la SBS. Tu dinero protegido en cada operación."
    ctaLabel="Abrir cuenta gratis"
    ctaHref="https://app.business-dollar.pe/register"
  />
</PageLayout>
