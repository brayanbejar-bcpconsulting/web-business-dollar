---
/**
 * contacto/gracias.astro
 * Página de confirmación post-formulario de contacto.
 * noindex: true — no debe aparecer en buscadores.
 * Referencia: docs/context/project-roadmap.md → Fase 2.6
 */
import PageLayout from "../../layouts/PageLayout.astro";
import Button from "../../components/atoms/Button.astro";
---

<PageLayout
  title="Mensaje enviado — Business Dollar"
  description="Tu mensaje ha sido recibido. Nuestro equipo te responderá pronto."
  noindex={true}
  hideBreadcrumbs={true}
>
  <section class="min-h-[70vh] flex items-center justify-center py-20 bg-white">
    <div class="max-w-xl mx-auto px-4 sm:px-6 text-center">

      <!-- Icono de éxito -->
      <div class="flex items-center justify-center w-20 h-20 rounded-full bg-green-100 mx-auto mb-6">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="40"
          height="40"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-green-600"
          aria-hidden="true"
        >
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
          <polyline points="22 4 12 14.01 9 11.01" />
        </svg>
      </div>

      <h1 class="font-display text-3xl font-bold text-neutral-900 mb-3">
        Mensaje recibido
      </h1>
      <p class="text-lg text-neutral-600 mb-2">
        Gracias por escribirnos.
      </p>
      <p class="text-neutral-500 mb-8 leading-relaxed">
        Nuestro equipo revisará tu consulta y te responderá en un plazo de
        <strong class="text-neutral-700">24 horas hábiles</strong> al correo electrónico
        que proporcionaste.
      </p>

      <!-- Mientras esperas -->
      <div class="bg-neutral-50 rounded-xl border border-neutral-200 p-6 mb-8 text-left">
        <p class="text-sm font-semibold text-neutral-700 mb-4">Mientras esperas, puedes:</p>
        <div class="space-y-3">
          <a
            href="/servicios"
            class="flex items-center gap-3 p-3 bg-white rounded-lg border border-neutral-200 hover:border-primary-300 hover:bg-primary-50/30 transition-colors group"
          >
            <div class="w-9 h-9 rounded-lg bg-primary-100 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-600" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-neutral-800 group-hover:text-primary-700 transition-colors">Cómo funciona Business Dollar</p>
              <p class="text-xs text-neutral-500">Conoce el proceso de cambio paso a paso</p>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-neutral-400 ml-auto shrink-0" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </a>

          <a
            href="/preguntas-frecuentes"
            class="flex items-center gap-3 p-3 bg-white rounded-lg border border-neutral-200 hover:border-primary-300 hover:bg-primary-50/30 transition-colors group"
          >
            <div class="w-9 h-9 rounded-lg bg-primary-100 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-600" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-neutral-800 group-hover:text-primary-700 transition-colors">Preguntas frecuentes</p>
              <p class="text-xs text-neutral-500">Quizás tu respuesta ya está aquí</p>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-neutral-400 ml-auto shrink-0" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </a>

          <a
            href="/blog/como-cambiar-dolares-online"
            class="flex items-center gap-3 p-3 bg-white rounded-lg border border-neutral-200 hover:border-primary-300 hover:bg-primary-50/30 transition-colors group"
          >
            <div class="w-9 h-9 rounded-lg bg-primary-100 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-600" aria-hidden="true"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-neutral-800 group-hover:text-primary-700 transition-colors">Guía: cómo cambiar dólares online</p>
              <p class="text-xs text-neutral-500">Paso a paso para tu primera operación</p>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-neutral-400 ml-auto shrink-0" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </div>

      <!-- CTA -->
      <div class="border-t border-neutral-200 pt-6">
        <p class="text-sm text-neutral-500 mb-4">¿Listo para tu primera operación?</p>
        <Button href="https://app.business-dollar.pe/register" variant="primary" size="md" target="_blank">
          Abrir cuenta gratis
        </Button>
      </div>

    </div>
  </section>
</PageLayout>
